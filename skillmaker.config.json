{
  "schemaVersion": 1,
  "name": "skillmaker-studio",
  "skillsDir": "skills",
  "viewer": {
    "port": 4323
  },
  "trackRuns": true,
  "providers": {
    "claude-code": {
      "command": [
        "npx",
        "-y",
        "@zed-industries/claude-code-acp@latest"
      ]
    },
    "codex": {
      "command": [
        "npx",
        "-y",
        "@agentclientprotocol/codex-acp@latest"
      ]
    }
  },
  "publishTargets": [
    {
      "id": "dist-skills",
      "kind": "git-dir",
      "path": "dist/skills"
    },
    {
      "id": "claude-marketplace",
      "kind": "claude-marketplace"
    }
  ]
}
