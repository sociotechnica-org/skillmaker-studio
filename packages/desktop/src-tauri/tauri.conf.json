{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skillmaker Studio",
  "version": "0.0.0",
  "identifier": "studio.skillmaker.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skillmaker Studio",
        "url": "index.html",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "theme": null,
        "backgroundColor": "#18181b"
      }
    ],
    "security": {
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/skillmaker"],
    "macOS": {
      "files": {
        "MacOS/viewer-dist": "binaries/viewer-dist"
      }
    }
  }
}
