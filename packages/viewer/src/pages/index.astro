---
// The root IS the shell (root swap, 2026-07-23). The prior five-tab app
// was retired with it; its code remains in src/app/ pending cleanup.
import NextShell from "../app/next/NextShell.tsx";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Skillmaker Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
    <!-- Apply the theme before paint so there's no light→dark flash.
         Explicit choice (localStorage "sm-theme") wins; first visit follows
         the OS. Mirrors app/next/theme.ts — keep the two in sync. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("sm-theme");
          var dark =
            stored === "dark" ||
            (stored !== "light" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          if (dark) document.documentElement.classList.add("dark");
        } catch {}
      })();
    </script>
  </head>
  <body class="min-h-screen text-ink antialiased">
    <NextShell client:load />
  </body>
</html>
