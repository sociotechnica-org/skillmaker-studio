---
import Faq from "../components/Faq.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Pillars from "../components/Pillars.astro";
import Receipts from "../components/Receipts.astro";
import Situations from "../components/Situations.astro";
import VsTheBench from "../components/VsTheBench.astro";
import Why from "../components/Why.astro";
import "../styles/global.css";

const title = "Skillmaker Studio — Ship agent skills with receipts.";
const description =
  "Skillmaker Studio turns SKILL.md from a paste of unknown pedigree into a measured, versioned, human-approved product — research, design rationale, eval fixtures, and pass rates included.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="data:," />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased">
    <Header />
    <main>
      <Hero />
      <Why />
      <Situations />
      <Pillars />
      <HowItWorks />
      <VsTheBench />
      <Receipts />
      <Features />
      <Faq />
    </main>
    <Footer />
  </body>
</html>
