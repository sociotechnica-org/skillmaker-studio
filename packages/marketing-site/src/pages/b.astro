---
// Spine B — the pull infomercial, one continuous motion (Turbo Pump grammar).
// Round 5 (2026-07-16, director rulings): one cold open only — the old enemy
// story and pain cave merged into THE LINEUP: the full suspects table for why
// a skill goes from appearing-to-work to appearing-to-fail, managed to reality
// (15 suspects, 6 families), each with a "how you'd know today" column whose
// answers are the cave. Machine reveal: "One machine. The whole lineup."
// Fan-out reframed (director ruling): not "other days it breaks" but the OTHER
// JOBS on the same workbench — better/cheaper/faster commissions, voiced as the
// asks a prompt engineer actually receives, each with the silent "…and don't
// break it" suffix that makes them measurement problems.
// Copy rationale: docs/gtm/2026-07-12-pull-driven-sales/voc-language-research-2026-07-16.md
//                 docs/gtm/2026-07-12-pull-driven-sales/competitor-landscape-2026-07-16.md
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";

const repoUrl = "https://github.com/sociotechnica-org/skillmaker-studio";
const issuesUrl = "https://github.com/sociotechnica-org/skillmaker-studio/issues";
const installLines = [
  "curl -fsSL https://skillmaker.studio/install.sh | sh",
  "skillmaker adopt",
];

const title = "Skillmaker Studio — Your agent did something weird again.";
const description =
  "Skills drift in a world that never stops changing them. Skillmaker Studio turns drift into a number, blame into a lookup, and breakage into a fix — receipts on every skill.";

const lineup = [
  {
    family: "the world changed",
    suspects: [
      { s: "The model changed.", today: "You find out when it breaks." },
      { s: "The model got quietly tuned. Or nerfed.", today: "Vibes and a Reddit thread." },
      { s: "It ran on a model it was never rated for.", today: "Nobody checks." },
      { s: "The agent runtime updated.", today: "Page 40 of a changelog." },
    ],
  },
  {
    family: "its neighborhood changed",
    suspects: [
      { s: "The skill that feeds it changed its handoff.", today: "You wouldn't know." },
      { s: "The skill it hands off to wants something new.", today: "Blame lands on the wrong skill." },
      { s: "The general prompt shifted around it.", today: "Who'd tell you?" },
      { s: "New skills are crowding the context.", today: "Invisible." },
    ],
  },
  {
    family: "someone changed it",
    suspects: [
      { s: "A teammate “improved” it. Same name.", today: "You find out in the incident." },
      { s: "It forked. You're reading the wrong copy.", today: "They look identical." },
    ],
  },
  {
    family: "it was never right",
    suspects: [
      { s: "Wrong process from day one.", today: "Runs clean. Fails quietly." },
      { s: "Too broad, too narrow, or too long.", today: "It half-fires. Silently." },
      { s: "The vibe check flattered it.", today: "There was never a baseline." },
    ],
  },
  {
    family: "the job changed",
    suspects: [
      { s: "You started asking for things at the edge of its scope.", today: "Feels like the skill's fault." },
    ],
  },
  {
    family: "nothing happened at all",
    suspects: [
      { s: "A 1-in-1,000 fluke, caught in the spotlight.", today: "Indistinguishable from everything above." },
    ],
  },
];

const story = [
  {
    shot: "01",
    frame: "$ skillmaker adopt",
    caption:
      "That skill everyone quietly distrusts? Bring it into the studio first. Nothing moves — it becomes measurable right where it lives.",
  },
  {
    shot: "02",
    frame: "what does “good” mean?",
    caption:
      "You and the agent write down what it's actually supposed to do — evals in plain English. For most skills, this is the first time it's ever been written down.",
  },
  {
    shot: "03",
    frame: "$ skillmaker run",
    caption:
      "The first honest number. Lower than the vibe check promised — and the first time you can see the flake instead of just feeling it.",
  },
  {
    shot: "04",
    frame: "the operating table",
    caption:
      "Trail each failure back to the choice that caused it. Fix the process, not just the prompt.",
  },
  {
    shot: "05",
    frame: "green, with a receipt",
    caption:
      "Re-measure. The number climbs, pinned to the exact version and model that earned it. The problem child has a report card.",
  },
  {
    shot: "06",
    frame: "now the rest of them",
    caption:
      "Adopt the whole repo. Every skill gets the same treatment; every new skill is born this way. Next time a model changes under you, the board tells you — not a customer.",
  },
];

const wild = [
  {
    quote: "AI is not a tool, it's a tiny Kafkaesque bureaucracy inside of your codebase.",
    source: "Hacker News",
    url: "https://news.ycombinator.com/item?id=43683012",
  },
  {
    quote:
      "Application prompts overfit the model they are using… Switch model, the prompt no longer produces the output you expect.",
    source: "Hacker News",
    url: "https://news.ycombinator.com/item?id=48868086",
  },
  {
    quote:
      "I keep it adhoc - models change so frequently that prompts are always broken all the time.",
    source: "Ask HN",
    url: "https://news.ycombinator.com/item?id=42325485",
  },
];

const asks = [
  {
    family: "quality",
    pings: [
      "“Can we get the pass rate up — without regressing what already passes?”",
      "“Use it as the base for the gnarlier version.”",
      "“New model dropped. Half these instructions are probably obsolete.”",
      "“‘Trust me’ won't pass review. Where are the evals?”",
    ],
  },
  {
    family: "cost",
    pings: [
      "“Same output, half the tokens.”",
      "“Does it really need the big model?”",
      "“Does this really need 17 steps?”",
      "“Which of these 89 skills are dead weight?”",
      "“Can we stop human-reviewing every output?”",
    ],
  },
];

const objections = [
  {
    q: "“Do we have to restructure our repo?”",
    a: "No. adopt works in place — 59/60 and 39/39 skills adopted cleanly on real public repos. Zero files moved.",
  },
  {
    q: "“I'm not an evals person.”",
    a: "You don't need to be. If your current process is a vibe check, that's a real start — our agents help you write it down in plain English and make it repeatable. You judge; they build.",
  },
  {
    q: "“Isn't git + CI enough?”",
    a: "Git shows that the file changed. It can't show whether behavior changed, on which model, or why. Receipts live next to the skill in your repo — git-native — but they carry the number git can't.",
  },
  {
    q: "“Won't the numbers flatter you?”",
    a: "They refuse to. Three runs reads “below smoke” on our own case study — even when the percentage looks great.",
  },
  {
    q: "“Where does my data go?”",
    a: "Nowhere. Free, local, MIT-licensed, no account. It phones nothing home.",
  },
  {
    q: "“And when you get acquired?”",
    a: "Your receipts are plain files in your git history. If we vanished tomorrow, your evidence wouldn't. No account, no cloud, nothing to sunset.",
  },
  {
    q: "“Isn't this slower than just shipping it?”",
    a: "Up front? Yes. Writing down what good means takes real time — the vibe check is faster, right up until the weird Tuesday. You pay the hours either way: once here, on purpose, with a receipt. Or every incident, in the dark.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="data:," />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased">
    <Header />
    <main>
      <!-- THE PULL — the only cold open -->
      <section class="mx-auto max-w-5xl px-6 pb-14 pt-16 sm:pt-24">
        <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the pull</p>
        <h1 class="max-w-3xl text-4xl font-semibold leading-[1.1] tracking-tight text-ink sm:text-5xl">
          Your agent did something weird again.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-dim">
          No crash. No error. Nothing your dashboards will catch — just
          <em>confidently wrong</em>, in front of someone who matters. And you
          can&#39;t say why, which version did it, or what changed.
        </p>
      </section>

      <!-- THE LINEUP — enemy + cave, merged: the suspects table -->
      <section class="border-y border-border bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-14">
          <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the enemy</p>
          <h2 class="max-w-3xl text-2xl font-semibold leading-snug tracking-tight text-ink sm:text-3xl">
            Meet the suspects.
          </h2>
          <p class="mt-4 max-w-2xl leading-relaxed text-ink-dim">
            So you go to find out what happened. The lineup is long.
          </p>

          <div class="mt-8 max-w-3xl">
            <div class="flex items-baseline justify-between gap-4 border-b-2 border-border pb-2">
              <span class="font-mono text-xs uppercase tracking-widest text-ink-dim">suspect</span>
              <span class="font-mono text-xs uppercase tracking-widest text-ink-dim">how you&#39;d know today</span>
            </div>
            {
              lineup.map((group) => (
                <div class="mt-6">
                  <p class="font-mono text-xs uppercase tracking-widest text-accent">{group.family}</p>
                  <ul>
                    {group.suspects.map((item) => (
                      <li class="flex items-baseline justify-between gap-6 border-b border-border py-2.5">
                        <span class="font-medium text-ink">{item.s}</span>
                        <span class="shrink-0 text-right font-mono text-xs text-ink-dim">{item.today}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>

          <p class="mt-8 max-w-3xl font-medium leading-relaxed text-ink">
            All real. Usually several at once. Each wants a different fix — patch
            a fluke and you injure a healthy skill. And nothing you have can tell
            you which one you&#39;re looking at. That&#39;s the cave.
          </p>
        </div>
      </section>

      <!-- THE MACHINE -->
      <section class="mx-auto max-w-5xl px-6 py-14">
        <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the machine</p>
        <h2 class="max-w-3xl text-2xl font-semibold leading-snug tracking-tight text-ink sm:text-3xl">
          Skillmaker Studio is the machine that keeps up.
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-dim">
          The skill is the part of your agent you can actually operate on —
          and the studio is where your skills live with receipts: what each
          one passed, on which version, on which model, re-checked when the
          world moves, like a canary that never sleeps. Drift becomes a
          number. Blame becomes a lookup. Breakage becomes a work order.
          Model changes under you? Re-run the receipts and know what survived
          by lunch.
        </p>
        <p class="mt-4 max-w-2xl font-medium leading-relaxed text-ink">
          One machine. The whole lineup.
        </p>
      </section>

      <!-- WATCH IT HAPPEN — the storyboard IS the demo -->
      <section class="border-y border-border bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-14">
          <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">watch it happen</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            Bring the problem child in first.
          </h2>
          <p class="mt-4 max-w-2xl leading-relaxed text-ink-dim">
            You have one — the skill everyone works around. Ours was a 17-step
            monster tracked across four tabs, an eval bench, and a spreadsheet
            before we built the studio. Here&#39;s its week inside, and what
            happens after.
          </p>

          <ol class="mt-8 grid gap-px overflow-hidden rounded-lg border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
            {
              story.map((s) => (
                <li class="bg-canvas p-6">
                  <span class="font-mono text-xs text-accent">{s.shot}</span>
                  <p class="mt-2 font-mono text-base text-ink">{s.frame}</p>
                  <p class="mt-3 text-sm leading-relaxed text-ink-dim">{s.caption}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <!-- THE SECRET -->
      <section class="mx-auto max-w-5xl px-6 py-14">
        <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the secret</p>
        <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
          The secret is the trail.
        </h2>
        <p class="mt-4 max-w-3xl leading-relaxed text-ink-dim">
          Every number is pinned to the exact skill version and model that earned
          it. Every design choice is linked to the evidence behind it. So when a
          skill is stable but wrong — running clean, doing the job badly — you can
          see it, trace it, and fix the process, not just the prompt. And the
          culprit question — model, skill, teammate, you — becomes a lookup,
          not a fight.
        </p>
        <p class="mt-4 max-w-3xl font-medium leading-relaxed text-ink">
          Drift doesn&#39;t stop. It stops mattering.
        </p>
      </section>

      <!-- THE WILD — verified public quotes -->
      <section class="border-y border-border bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-14">
          <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the wild</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
            You&#39;ve already said it.
          </h2>
          <div class="mt-8 grid gap-6 sm:grid-cols-3">
            {
              wild.map((w) => (
                <figure class="rounded-lg border border-border bg-canvas p-6">
                  <blockquote class="text-sm leading-relaxed text-ink">“{w.quote}”</blockquote>
                  <figcaption class="mt-3">
                    <a
                      href={w.url}
                      class="font-mono text-xs text-accent transition hover:text-accent-dim"
                      rel="noreferrer"
                    >
                      — {w.source} &rarr;
                    </a>
                  </figcaption>
                </figure>
              ))
            }
          </div>
          <p class="mt-6 font-mono text-xs text-ink-dim">
            Verbatim, from public threads. Links included — receipts, even here.
          </p>
        </div>
      </section>

      <!-- THE FAN-OUT — the other jobs on the same workbench -->
      <section class="mx-auto max-w-5xl px-6 py-14">
        <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the other asks</p>
        <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
          Quality. Cost.
        </h2>
        <p class="mt-4 max-w-2xl leading-relaxed text-ink-dim">
          When nothing&#39;s broken, this is what lands in your DMs instead.
        </p>
        <div class="mt-8 max-w-3xl space-y-6">
          {
            asks.map((group) => (
              <div>
                <p class="font-mono text-xs uppercase tracking-widest text-accent">{group.family}</p>
                <div class="mt-3 flex flex-wrap gap-3">
                  {group.pings.map((ping) => (
                    <span class="rounded-full border border-border bg-surface px-4 py-2 text-sm text-ink">
                      {ping}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
        <p class="mt-8 max-w-3xl font-medium leading-relaxed text-ink">
          Every ask carries the same silent suffix: “…and don&#39;t break it.”
          You can&#39;t promise that on vibes. Same machine.
        </p>
      </section>

      <!-- OBJECTIONS -->
      <section class="border-y border-border bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-14">
          <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">you&#39;re already objecting. good.</p>
          <div class="grid gap-6 sm:grid-cols-2">
            {
              objections.map((o) => (
                <div class="rounded-lg border border-border bg-canvas p-6">
                  <h3 class="font-semibold text-ink">{o.q}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink-dim">{o.a}</p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ACT -->
      <section class="border-t border-border bg-surface">
        <div class="mx-auto max-w-5xl px-6 py-16">
          <p class="mb-4 font-mono text-xs uppercase tracking-widest text-accent">the next ninety seconds</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">Find out first.</h2>

          <div class="mt-8 max-w-3xl rounded-lg border border-border bg-canvas shadow-2xl shadow-black/40">
            <div class="flex items-center justify-between border-b border-border px-4 py-3">
              <div class="flex items-center gap-1.5" aria-hidden="true">
                <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
              </div>
              <span class="font-mono text-xs text-ink-dim">ninety seconds</span>
              <span></span>
            </div>
            <pre class="overflow-x-auto px-4 py-4 font-mono text-[13px] leading-relaxed text-ink">{installLines.map((line) => `$ ${line}`).join("\n")}</pre>
            <p class="border-t border-border px-4 py-3 text-xs text-ink-dim">
              Free. Local. MIT. Phones nothing home. On the repo you already have.
            </p>
          </div>

          <p class="mt-8 max-w-2xl text-sm leading-relaxed text-ink-dim">
            Want hands-on help? We&#39;re working with a small first round of design
            partners —
            <a href={issuesUrl} class="text-accent transition hover:text-accent-dim" rel="noreferrer">open an issue</a>
            and tell us what broke. Running skills as a team?
            <a href={issuesUrl} class="text-accent transition hover:text-accent-dim" rel="noreferrer">Talk to us</a>
            — we&#39;re designing the multi-player studio with a handful of companies.
          </p>

          <div class="mt-12 max-w-3xl border-t border-border pt-10">
            <p class="leading-relaxed text-ink-dim">
              We can&#39;t make your agent predictable — nobody can; that&#39;s what
              you hired it for. We can make sure nothing drifts silently, nothing
              fails anonymously, and nothing stays wrong. And the next time it goes
              weird, you won&#39;t sit there wondering if you&#39;re crazy. You&#39;ll
              look it up.
            </p>
            <p class="mt-4 text-lg font-medium text-ink">The only thing you risk is finding out.</p>
            <p class="mt-8">
              <a href={repoUrl} class="text-sm font-medium text-accent transition hover:text-accent-dim" rel="noreferrer">
                View on GitHub &rarr;
              </a>
            </p>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
