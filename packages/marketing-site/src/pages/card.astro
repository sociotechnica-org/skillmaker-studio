---
// Standalone view of the wide SkillCard (the same component embedded in the
// homepage). Scratch route (/card); safe to delete once the card is settled.
import SkillCard from "../components/SkillCard.astro";
import "../styles/global.css";
const title = "Skill card — mockup";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="data:," />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-canvas text-ink antialiased">
    <main class="mx-auto max-w-5xl px-6 py-12">
      <p class="mb-6 text-center font-mono text-[10px] uppercase tracking-[0.2em] text-accent">
        skill card · wide · real skill, illustrative figures
      </p>
      <SkillCard />
    </main>
  </body>
</html>
