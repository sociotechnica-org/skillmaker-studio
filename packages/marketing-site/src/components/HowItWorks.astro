---
const steps = [
  {
    command: "skillmaker adopt",
    title: "Point it at the repo you already have.",
    body: "Nothing moves, nothing restructures. Your existing skills become measurable in place.",
  },
  {
    title: "Decide what good means.",
    body: "Design evals where the skill lives — our agents help you choose what to test and build the fixtures, in plain English. No eval background required.",
  },
  {
    command: "skillmaker run",
    title: "Read the receipts.",
    body: "Run against the real agent enough times to get a real number — n, pass rate, confidence interval — pinned to the exact skill version and model that earned it. When the number moves, you know first.",
  },
];

// TODO(honesty): re-capture this transcript from the real CLI before public deploy — see site-strategy-2026-07-15.md §7
const session = [
  {
    cmd: "skillmaker adopt",
    out: "skillmaker: found 12 skills in ./skills\nskillmaker: adopted 12/12 in place — 0 files moved",
  },
  {
    cmd: "skillmaker status bash-guardrails",
    out: [
      "slug:        bash-guardrails",
      "stage:       evaluating",
      "fixtures:    5",
      "coverage:    3 covered, 1 partial, 1 gap",
    ].join("\n"),
  },
  { cmd: "skillmaker start", out: "skillmaker: serving my-skills at http://localhost:4322" },
];
---

<section id="how-it-works" class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
  <h2 class="text-2xl font-semibold tracking-tight text-ink">How it works</h2>

  <ol class="mt-8 grid gap-6 sm:grid-cols-3">
    {
      steps.map((step, index) => (
        <li class="rounded-lg border border-border bg-surface p-6">
          <span class="font-mono text-xs text-accent">{`Step ${index + 1}`}</span>
          {step.command && (
            <code class="mt-2 block font-mono text-sm text-ink">{step.command}</code>
          )}
          <h3 class="mt-2 text-base font-semibold text-ink">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-dim">{step.body}</p>
        </li>
      ))
    }
  </ol>

  <div class="mt-12 rounded-lg border border-border bg-surface shadow-xl shadow-black/30">
    <div class="flex items-center justify-between border-b border-border px-4 py-3">
      <div class="flex items-center gap-1.5" aria-hidden="true">
        <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-ink/15"></span>
      </div>
      <span class="font-mono text-xs text-ink-dim">the adopt motion</span>
      <span></span>
    </div>
    <pre class="overflow-x-auto px-4 py-4 font-mono text-[13px] leading-relaxed text-ink">{
      session
        .map((step) => `$ ${step.cmd}\n${step.out}`)
        .join("\n\n")
    }</pre>
  </div>
</section>
