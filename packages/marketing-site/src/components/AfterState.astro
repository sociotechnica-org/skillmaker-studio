---
const changes = [
  {
    lead: "The weirdness surfaces on your terms.",
    body: "A number moved on a dashboard you check — not in a customer thread you dread. You knew first.",
  },
  {
    lead: "Blame resolves in one look.",
    body: "The version you shipped passed on the model it was rated for; the thing that failed was a mutation on a model it never met. Thirty seconds, settled.",
  },
  {
    lead: "The hunting stops.",
    body: "The research, the versions, the evals, and the reasoning live where the skill lives. Nothing orphaned, nothing in a tab you can't find.",
  },
  {
    lead: "Fixes happen on an operating table.",
    body: "Trail back to why, change the process — not just the prompt — and re-measure on the spot.",
  },
];
---

<section id="with-custody" class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
  <div class="max-w-3xl">
    <p class="mb-4 text-sm font-medium uppercase tracking-widest text-accent">with custody</p>
    <h2 class="text-2xl font-semibold tracking-tight text-ink sm:text-3xl">
      What changes when someone owns the skill.
    </h2>
  </div>

  <div class="mt-10 grid gap-6 sm:grid-cols-2">
    {
      changes.map((change) => (
        <div class="rounded-lg border border-border bg-surface p-6">
          <p class="text-lg font-semibold text-ink">{change.lead}</p>
          <p class="mt-3 text-sm leading-relaxed text-ink-dim">{change.body}</p>
        </div>
      ))
    }
  </div>
</section>
