---
const repoUrl = "https://github.com/sociotechnica-org/skillmaker-studio";
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-8 text-xs text-ink-dim sm:flex-row sm:items-center sm:justify-between"
  >
    <p>&copy; {year} SocioTechnica &middot; MIT licensed</p>
    <a href={repoUrl} class="transition hover:text-ink" rel="noreferrer">
      github.com/sociotechnica-org/skillmaker-studio
    </a>
  </div>
</footer>
