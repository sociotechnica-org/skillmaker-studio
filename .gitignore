# Dependencies and build output
node_modules/
dist/
.astro/

# Skillmaker runtime dir: everything untracked EXCEPT the journal.
# .skillmaker/events.jsonl is append-only shared history (merge=union in
# .gitattributes) and must stay in git; studio.db, local.json, and claims/
# are per-machine runtime state.
.skillmaker/*
!.skillmaker/events.jsonl

.repos/effect

# Tauri desktop shell build output: cargo target dir, and the staged
# sidecar binary + viewer-dist (scripts/prepare-desktop-sidecar.sh's
# output -- target-triple- and machine-specific, derived from dist/).
packages/desktop/src-tauri/target/
packages/desktop/src-tauri/binaries/
packages/desktop/src-tauri/gen/
