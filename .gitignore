# Dependencies and build output
node_modules/
# Only ignore dist/'s direct children (not dist/ itself) so dist/skills/
# below can be re-included -- git cannot re-include a file whose parent
# directory is itself excluded.
dist/*
.astro/

# Exception: dist/skills/ is the self-hosted workspace's git-dir publish
# target (skillmaker.config.json publishTargets "dist-skills") -- published
# skill output, not release-build scratch, and is real repo history.
!dist/skills/

# Skillmaker runtime dir: everything untracked EXCEPT the journal.
# .skillmaker/events.jsonl is append-only shared history (merge=union in
# .gitattributes) and must stay in git; studio.db, local.json, and claims/
# are per-machine runtime state.
.skillmaker/*
!.skillmaker/events.jsonl

.repos/effect

# Viewer static build output (bun run build:viewer) -- machine-local build
# scratch needed to `skillmaker start` locally, not release history.
packages/viewer/dist/

# Brand assets synced into app public/ dirs by scripts/sync-brand-assets.ts.
# The tracked source of truth lives in assets/brand/ -- these are generated
# copies, regenerated on each app's dev/build. Don't edit or commit them.
packages/viewer/public/skillmaker-logo.png

# Tauri desktop shell build output: cargo target dir, and the staged
# sidecar binary + viewer-dist (scripts/prepare-desktop-sidecar.sh's
# output -- target-triple- and machine-specific, derived from dist/).
packages/desktop/src-tauri/target/
packages/desktop/src-tauri/binaries/
packages/desktop/src-tauri/gen/
npm/cli-darwin-arm64/bin/
npm/cli-darwin-arm64/viewer-dist/
npm/cli-linux-x64/bin/
npm/cli-linux-x64/viewer-dist/
# dist/npm/ (build-npm-packages.sh's output) is already covered by dist/*
# above; noted here for discoverability.
